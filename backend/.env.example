# Copier ce fichier en .env à la racine du serveur (même dossier que package.json).
# HidenCloud : créer via gestionnaire de fichiers ou SFTP — pas de panneau env sur tous les plans.

JWT_SECRET=change-me-in-production
PORT=3000
# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:5173,https://happyletsgo.fr,https://www.happyletsgo.fr

# Resend — https://resend.com
RESEND_API_KEY=re_xxxxxxxx
# Prod : expéditeur sur domaine vérifié (ex. noreply@happyletsgo.fr)
EMAIL_FROM=Nel <onboarding@resend.dev>

# URL publique du frontend (lien « Vérifier mon email » → ?verifyEmail=…)
# Dev : http://localhost:5173 — Prod : https://happyletsgo.fr
APP_PUBLIC_URL=https://happyletsgo.fr
