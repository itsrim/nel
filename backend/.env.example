# Backend — complète le .env RACINE (../.env) qui contient déjà Google Sheets.
# Le serveur charge d’abord ../.env puis ce fichier (override).

JWT_SECRET=change-me-in-production
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,https://happyletsgo.fr,https://www.happyletsgo.fr

MAILJET_API_KEY=
MAILJET_API_SECRET=
EMAIL_FROM=Happy Let's GO <noreply@happyletsgo.fr>
APP_PUBLIC_URL=https://happyletsgo.fr

SKIP_EMAIL_VERIFICATION=false

# ── Google Sheets : PAS besoin de dupliquer si déjà dans ../.env ───────────
# Le backend lit les mêmes variables que le front :
#   VITE_GOOGLE_SHEETS_URL_ENCODED
#   VITE_GOOGLE_SHEETS_API_URL
#   VITE_SHEET_GID_VIEWER_SETTINGS, VITE_SHEET_GID_MESSAGES, etc.
#
# Optionnel — onglet push (ajouter le gid si tu utilises Web Push) :
# VITE_SHEET_GID_PUSH_SUBSCRIPTIONS=

# Optionnel — Web Push (npm run vapid)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@happyletsgo.fr
