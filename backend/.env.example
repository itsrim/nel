# Variables Render (Dashboard → Environment) ou .env local pour npm run dev

JWT_SECRET=change-me-in-production
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,https://happyletsgo.fr,https://www.happyletsgo.fr

# ── Email (recommandé : Brevo SMTP via Nodemailer) ──
# 1. Créer un compte sur https://www.brevo.com
# 2. Paramètres → SMTP & API → clé SMTP
# 3. Vérifier le domaine expéditeur (happyletsgo.fr) ou utiliser l'email Brevo en dev
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-login-email@example.com
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=Happy Let's GO <noreply@happyletsgo.fr>

# Legacy Mailjet (optionnel — utilisé seulement si SMTP absent ou en secours)
# MAILJET_API_KEY=
# MAILJET_API_SECRET=

APP_PUBLIC_URL=https://happyletsgo.fr

# Lecture de skipEmailVerification depuis l'onglet app_config (export CSV public du Sheet)
# Ex. https://docs.google.com/spreadsheets/d/XXX/export?format=csv&gid=GID_APP_CONFIG
APP_CONFIG_CSV_URL=
# Secours immédiat sans email : valide les comptes sans lien de vérification
SKIP_EMAIL_VERIFICATION=false

# Optionnel — Web Push (npm run vapid)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@happyletsgo.fr
