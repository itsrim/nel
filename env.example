# Ne pas commiter ce fichier (déjà dans .gitignore).
# ImageKit — clé privée pour signer les uploads.
VITE_IMAGEKIT_PRIVATE_KEY=private_key

# Google OAuth — client Web (Console Google Cloud → Identifiants OAuth).
# Remplace par l’ID du client « Application Web » (forme xxx.apps.googleusercontent.com).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=privatekey.apps.googleusercontent.com
# Si tu avais une valeur sous l’ancienne clé erronée « EXPO= », colle-la dans la ligne ci-dessus :
# H_ndIdj8PkvqFHLjobw4a-d6h9QXNEO5jvwkzuVp

# Backend chat — URL Render (HTTPS, sans slash final).
# Après déploiement : https://<nom-du-service>.onrender.com
# Dev local : http://localhost:3000
VITE_CHAT_API_URL=https://hlg-api.onrender.com

# Web Push — clé publique VAPID (générer avec : cd backend && npm run vapid)
VITE_VAPID_PUBLIC_KEY=

# Google Sheets (BDD CSV) — voir google-apps-script/README.md
# URL du type https://docs.google.com/spreadsheets/d/XXX/edit?usp=sharing encodée (+1 par caractère)
VITE_GOOGLE_SHEETS_URL_ENCODED=
# URL de l’Apps Script déployé (POST / PUT)
VITE_GOOGLE_SHEETS_API_URL=
# GID de l’onglet "messages" (dans l’URL #gid=…)
VITE_SHEET_GID_MESSAGES=0
# GID des autres onglets (voir google-apps-script/README.md)
VITE_SHEET_GID_EVENTS=
VITE_SHEET_GID_CONVERSATIONS=
VITE_SHEET_GID_PROFILES=
VITE_SHEET_GID_SUGGESTIONS=
VITE_SHEET_GID_VIEWER_SETTINGS=
VITE_SHEET_GID_PROFILE_VISITS=
VITE_SHEET_GID_NOTIFICATIONS=
VITE_SHEET_GID_ADMIN_REPORTS=
VITE_SHEET_GID_PROFESSIONALS=
VITE_SHEET_GID_APP_CONFIG=
# CSV local de secours (défaut /csv/messages.csv)
VITE_DEFAULT_CSV_PATH=/csv/messages.csv

# URL publique du site (partage sorties, OAuth Google : origines autorisées)
# Prod : https://happyletsgo.fr — liens sorties : https://happyletsgo.fr/event/{id}
VITE_EVENT_PUBLIC_BASE_URL=https://happyletsgo.fr